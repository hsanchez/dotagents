{
  "description": "Load the dotagents skill-discovery meta-skill at session start.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "sh .codex/hooks/session-start.sh",
            "statusMessage": "Loading dotagents skill discovery"
          }
        ]
      }
    ]
  }
}
