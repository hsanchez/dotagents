#!/usr/bin/env sh
set -eu

dotagents_dir="$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)"
selected_providers="all"

usage() {
  printf '%s\n' \
    'Usage:' \
    '  .agents/agent init' \
    '  .agents/agent init --for all|<approved-provider>' \
    '  .agents/agent list' \
    '  .agents/agent skill install <local-path|owner/repo[/path]> [name]' \
    '  .agents/agent status' \
    '  .agents/agent update' \
    '  .agents/agent doctor' \
    '' \
    'Local host repo files:' \
    '  .rules.local' \
    '  .agents/local-skills/'
}

ensure_parent() {
  mkdir -p "$(dirname "$1")"
}

link_path() {
  target="$1"
  link="$2"

  ensure_parent "$link"
  if [ -e "$link" ] && [ ! -L "$link" ]; then
    echo "ERROR: refusing to replace existing non-symlink: $link" >&2
    exit 1
  fi
  ln -sfn "$target" "$link"
  echo "$link -> $target"
}

parse_manifest() {
  if ! command -v python3 >/dev/null 2>&1; then
    echo "ERROR: python3 is required to parse agents.toml" >&2
    exit 1
  fi
  if [ ! -f "$dotagents_dir/agents.toml" ]; then
    echo "ERROR: agents.toml not found: $dotagents_dir/agents.toml" >&2
    exit 1
  fi
  python3 -c '
import sys
if sys.version_info < (3, 11):
    print(f"ERROR: python3 3.11+ required for tomllib (found {sys.version})", file=sys.stderr)
    sys.exit(1)
import tomllib
import re
from pathlib import Path
try:
    data = tomllib.load(sys.stdin.buffer)
except Exception as e:
    print(f"ERROR parsing TOML: {e}", file=sys.stderr)
    sys.exit(1)
action = sys.argv[1]

def sync_entries(scope, entries):
    if entries is None:
        return []
    if not isinstance(entries, list):
        print(f"ERROR: {scope} must be an array of tables", file=sys.stderr)
        sys.exit(1)
    for entry in entries:
        if not isinstance(entry, dict):
            print(f"ERROR: {scope} entries must be tables", file=sys.stderr)
            sys.exit(1)
        source = entry.get("source")
        destination = entry.get("destination")
        if not source or not destination:
            print(f"ERROR: {scope} entries require source and destination", file=sys.stderr)
            sys.exit(1)
        yield source, destination

if action == "providers":
    print(" ".join(data.get("providers", {}).keys()))
elif action == "global-sync":
    for src, dest in sync_entries("sync", data.get("sync", [])):
        print(f"{src} {dest}")
elif action == "provider-sync":
    provider = sys.argv[2]
    sync_list = data.get("providers", {}).get(provider, {}).get("sync", [])
    for src, dest in sync_entries(f"providers.{provider}.sync", sync_list):
        print(f"{src} {dest}")
elif action == "validate":
    dotagents_path = Path(sys.argv[2]) if len(sys.argv) > 2 else None
    errors = []
    if data.get("version") != 1:
        errors.append("version must be 1")
    providers = data.get("providers", {})
    if not isinstance(providers, dict):
        errors.append("providers must be a table")
        providers = {}
    provider_pattern = re.compile(r"^[a-z][a-z0-9-]*$")
    destinations = {}

    def validate_path(scope, field, value):
        if not isinstance(value, str) or not value:
            errors.append(f"{scope}.{field} must be a non-empty string")
            return
        if value.startswith("/"):
            errors.append(f"{scope}.{field} must be repo-root-relative: {value}")
        if ".." in value.split("/"):
            errors.append(f"{scope}.{field} must not contain '..': {value}")
        if re.search(r"\s", value):
            errors.append(f"{scope}.{field} must not contain whitespace: {value}")

    def validate_source_exists(scope, source):
        if not dotagents_path or source == ".rules":
            return
        if source == ".rules":
            return
        if not (dotagents_path / source).exists():
            errors.append(f"{scope}.source does not exist: {source}")

    def validate_sync(scope, entries):
        for source, destination in sync_entries(scope, entries):
            validate_path(scope, "source", source)
            validate_path(scope, "destination", destination)
            validate_source_exists(scope, source)
            previous = destinations.get(destination)
            if previous:
                errors.append(f"duplicate destination {destination} in {scope}; first used by {previous}")
            else:
                destinations[destination] = scope

    validate_sync("sync", data.get("sync", []))
    for provider, config in providers.items():
        if not provider_pattern.match(provider):
            errors.append(f"invalid provider name: {provider}")
        if not isinstance(config, dict):
            errors.append(f"providers.{provider} must be a table")
            continue
        validate_sync(f"providers.{provider}.sync", config.get("sync", []))

    if errors:
        for error in errors:
            print(f"ERROR: agents.toml: {error}", file=sys.stderr)
        sys.exit(1)
    print("agents.toml: ok")
' "$@"
}

providers_list() {
  parse_manifest "providers" <"$dotagents_dir/agents.toml"
}

is_known_provider() {
  case "$1" in
  "" | .* | */*) return 1 ;;
  *)
    for p in $(providers_list); do
      if [ "$p" = "$1" ]; then
        return 0
      fi
    done
    return 1
    ;;
  esac
}

is_approved_provider() {
  is_known_provider "$1"
}

approved_providers() {
  providers_list | tr ' ' ',' | sed 's/,/, /g'
}

list_providers() {
  echo "Supported providers in this dotagents repo:"
  found="no"
  for provider in $(providers_list); do
    echo "  $provider"
    found="yes"
  done
  if [ "$found" = "no" ]; then
    echo "  none"
  fi
}

has_provider() {
  provider="$1"
  case " $selected_providers " in
  *" all "*) is_approved_provider "$provider" ;;
  *" $provider "*) return 0 ;;
  *) return 1 ;;
  esac
}

add_provider() {
  provider="$1"
  if [ "$provider" = "all" ]; then
    selected_providers="all"
    return
  fi
  if ! is_known_provider "$provider"; then
    echo "ERROR: provider not approved in this dotagents repo: $provider" >&2
    echo "Approved providers: $(approved_providers)" >&2
    echo "To approve it, add the provider under [providers] in the installed agents repo's agents.toml." >&2
    exit 2
  fi

  if [ "$selected_providers" = "all" ]; then
    selected_providers="$provider"
  else
    selected_providers="$selected_providers $provider"
  fi
}

relative_link_target() {
  source="$1"
  link="$2"
  parent="$(dirname "$link")"

  case "$source" in
  /*)
    echo "ERROR: manifest source must be repo-root-relative, not absolute: $source" >&2
    exit 1
    ;;
  esac

  source="${source#./}"
  if [ "$parent" = "." ]; then
    printf '%s\n' "$source"
    return
  fi

  prefix=""
  rest="${parent#./}"
  while [ -n "$rest" ] && [ "$rest" != "." ]; do
    prefix="../$prefix"
    case "$rest" in
    */*) rest="${rest#*/}" ;;
    *) break ;;
    esac
  done
  printf '%s%s\n' "$prefix" "$source"
}

link_repo_path() {
  source="$1"
  link="$2"
  if [ "$source" = ".rules" ]; then
    target="$(relative_link_target "$source" "$link")"
  else
    target="$(python3 -c 'import os, sys; print(os.path.relpath(sys.argv[1], sys.argv[2]))' "$dotagents_dir/$source" "$(pwd)/$(dirname "$link")")"
  fi
  link_path "$target" "$link"
}

# Legacy manifest parsing functions removed in favor of TOML config

compose_rules() {
  shared_rules="$dotagents_dir/rules/rules.md"
  if [ ! -f "$shared_rules" ]; then
    echo "ERROR: shared rules not found: $shared_rules" >&2
    exit 1
  fi

  {
    printf '<!-- Shared agent rules from the installed agents repo rules/rules.md -->\n\n'
    cat "$shared_rules"
    if [ -f ".rules.local" ]; then
      printf '\n\n<!-- Local repo rules from .rules.local -->\n\n'
      cat ".rules.local"
    fi
    printf '\n'
  } >.rules
  echo "Composed .rules"
}

preflight_skills() {
  if [ -d ".agents/skills" ]; then
    for entry in .agents/skills/* .agents/skills/.[!.]* .agents/skills/..?*; do
      [ -e "$entry" ] || [ -L "$entry" ] || continue
      if [ ! -L "$entry" ]; then
        echo "ERROR: refusing to replace unmanaged file in .agents/skills: $entry" >&2
        echo "Move it to .agents/local-skills/ or remove it before rerunning init." >&2
        exit 1
      fi
    done
  elif [ -e ".agents/skills" ] || [ -L ".agents/skills" ]; then
    echo "ERROR: refusing to replace existing non-directory: .agents/skills" >&2
    exit 1
  fi
}

compose_skills() {
  active_skills_dir="$(CDPATH='' cd -- "$(dirname -- ".agents/skills")" 2>/dev/null && pwd)/skills"
  shared_skills_dir="$dotagents_dir/skills"
  if [ -d "$shared_skills_dir" ] && [ "$active_skills_dir" = "$shared_skills_dir" ]; then
    echo ".agents/skills uses shared skills from installed agents repo"
    return 0
  fi

  preflight_skills
  if [ -d ".agents/skills" ]; then
    rm -f .agents/skills/* .agents/skills/.[!.]* .agents/skills/..?*
  fi
  mkdir -p .agents/skills

  if [ -d "$dotagents_dir/skills" ]; then
    for skill in "$dotagents_dir"/skills/*; do
      [ -d "$skill" ] || continue
      skill_name="$(basename "$skill")"
      target="$(python3 -c 'import os, sys; print(os.path.relpath(sys.argv[1], sys.argv[2]))' "$skill" "$(pwd)/.agents/skills")"
      ln -sfn "$target" ".agents/skills/$skill_name"
      echo ".agents/skills/$skill_name -> $target"
    done
  fi

  if [ -d ".agents/local-skills" ]; then
    for skill in .agents/local-skills/*; do
      [ -d "$skill" ] || continue
      skill_name="$(basename "$skill")"
      if [ -e ".agents/skills/$skill_name" ] || [ -L ".agents/skills/$skill_name" ]; then
        echo "Overriding shared skill with local skill: $skill_name"
        rm -f ".agents/skills/$skill_name"
      fi
      ln -sfn "../local-skills/$skill_name" ".agents/skills/$skill_name"
      echo ".agents/skills/$skill_name -> ../local-skills/$skill_name"
    done
  fi
}

sync_agents() {
  echo "Supported providers: $(approved_providers)"
  if [ "$dotagents_dir" = "$PWD" ]; then
    echo "Running inside shared template. Skipping host repo sync."
    echo "Agent environment synced."
    return 0
  fi

  compose_rules
  compose_skills

  parse_manifest "global-sync" <"$dotagents_dir/agents.toml" | while read -r src dest; do
    [ -n "$src" ] && [ -n "$dest" ] || continue
    link_repo_path "$src" "$dest"
  done

  for provider in $(providers_list); do
    if has_provider "$provider"; then
      echo "Syncing provider: $provider"
      parse_manifest "provider-sync" "$provider" <"$dotagents_dir/agents.toml" | while read -r src dest; do
        [ -n "$src" ] && [ -n "$dest" ] || continue
        link_repo_path "$src" "$dest"
      done
    fi
  done

  echo "Agent environment synced."
}

validate_skill() {
  skill_dir="$1"
  skill_name="$2"

  if [ ! -f "$skill_dir/SKILL.md" ]; then
    echo "ERROR: skill must contain SKILL.md: $skill_dir" >&2
    exit 1
  fi
  if ! grep -Eq "^name:[[:space:]]*${skill_name}[[:space:]]*$" "$skill_dir/SKILL.md"; then
    echo "ERROR: SKILL.md frontmatter name must match $skill_name" >&2
    exit 1
  fi
  if ! grep -Eq "^description:[[:space:]].+" "$skill_dir/SKILL.md"; then
    echo "ERROR: SKILL.md frontmatter must contain description" >&2
    exit 1
  fi
}

git_source_parts() {
  source="$1"
  owner="$(printf '%s' "$source" | cut -d / -f 1)"
  repo="$(printf '%s' "$source" | cut -d / -f 2)"
  subpath="$(printf '%s' "$source" | cut -s -d / -f 3-)"
  if [ -z "$owner" ] || [ -z "$repo" ] || [ "$owner" = "$source" ]; then
    echo "ERROR: skill source must be a local path or owner/repo[/path]" >&2
    exit 1
  fi
  printf '%s\n%s\n%s\n' "https://github.com/$owner/$repo.git" "$repo" "$subpath"
}

install_skill() {
  source="$1"
  explicit_name="${2:-}"
  mkdir -p .agents/local-skills

  if [ -d "$source" ]; then
    skill_name="${explicit_name:-$(basename "$source")}"
    destination=".agents/local-skills/$skill_name"
    validate_skill "$source" "$skill_name"
    rm -rf "$destination"
    cp -R "$source" "$destination"
  else
    tmp_dir="$(mktemp -d)"
    parts="$(git_source_parts "$source")"
    repo_url="$(printf '%s\n' "$parts" | sed -n '1p')"
    repo_name="$(printf '%s\n' "$parts" | sed -n '2p')"
    subpath="$(printf '%s\n' "$parts" | sed -n '3p')"
    git clone --depth 1 "$repo_url" "$tmp_dir/repo"
    skill_source="$tmp_dir/repo"
    if [ -n "$subpath" ]; then
      skill_source="$skill_source/$subpath"
    fi
    skill_name="${explicit_name:-$(basename "$skill_source")}"
    if [ "$skill_name" = "repo" ]; then
      skill_name="$repo_name"
    fi
    destination=".agents/local-skills/$skill_name"
    validate_skill "$skill_source" "$skill_name"
    rm -rf "$destination"
    cp -R "$skill_source" "$destination"
    rm -rf "$tmp_dir"
  fi

  echo "Installed local skill: $skill_name"
  sync_agents
}

doctor() {
  echo "dotagents: $dotagents_dir"
  command -v git >/dev/null 2>&1 && echo "git: ok" || echo "git: missing"
  if command -v python3 >/dev/null 2>&1; then
    python3 -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 11) else 1)' \
      && echo "python3: ok" \
      || echo "python3: missing 3.11+"
  else
    echo "python3: missing"
  fi
  parse_manifest "validate" "$dotagents_dir" <"$dotagents_dir/agents.toml"
  [ -f "$dotagents_dir/rules/rules.md" ] && echo "rules: ok" || echo "rules: missing"
  [ -d "$dotagents_dir/skills" ] && echo "skills: ok" || echo "skills: missing"
  echo "approved providers: $(approved_providers)"
}

status() {
  echo "dotagents: $dotagents_dir"
  [ -f ".rules" ] && echo "rules: composed" || echo "rules: missing"
  [ -f ".rules.local" ] && echo "local rules: yes" || echo "local rules: no"
  shared_count="$(find "$dotagents_dir/skills" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')"
  local_count="$(find .agents/local-skills -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')"
  echo "shared skills: $shared_count"
  echo "local skills: $local_count"
  echo "approved providers: $(approved_providers)"
}

update() {
  if [ -d "$dotagents_dir/.git" ]; then
    git -C "$dotagents_dir" pull --ff-only
  else
    echo "dotagents is not a git checkout: $dotagents_dir"
  fi
  sync_agents
}

command_name="init"
case "${1:-}" in
init | list | skill | status | update | doctor | help | -h | --help)
  command_name="$1"
  shift || true
  ;;
esac

case "$command_name" in
init)
  while [ "$#" -gt 0 ]; do
    case "$1" in
    --for)
      if [ -z "${2:-}" ]; then
        echo "ERROR: --for requires a value" >&2
        exit 2
      fi
      add_provider "$2"
      shift 2
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      usage
      exit 2
      ;;
    esac
  done
  sync_agents
  ;;
list)
  list_providers
  ;;
skill)
  if [ "${1:-}" != "install" ] || [ -z "${2:-}" ]; then
    usage
    exit 2
  fi
  install_skill "$2" "${3:-}"
  ;;
status)
  status
  ;;
update)
  update
  ;;
doctor)
  doctor
  ;;
-h | --help | help)
  usage
  ;;
*)
  usage
  exit 2
  ;;
esac
